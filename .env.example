# Authentification GitHub automatique
# Si USE_GITHUB_TOKEN=true, install_gh.sh utilisera GITHUB_TOKEN pour gh auth
USE_GITHUB_TOKEN=false
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# VS Code tunnel (optionnel)
VSCODE_TUNNEL_NAME=mon-serveur-code
# Note: VS Code tunnel utilise device flow GitHub pour la securite - auth ne peut pas etre automatisee

# Options optionnelles (install_all.sh)
# NODE_VERSION=22
