# ==============================================================================
# Exemple de configuration -- copiez ce fichier en .env et remplissez les valeurs
#   cp .env_example .env
# ==============================================================================


# ------------------------------------------------------------------------------
# GitHub CLI (install_gh.sh)
# Si USE_GITHUB_TOKEN=true, install_gh.sh utilisera GITHUB_TOKEN pour gh auth login
# Creer un token sur : https://github.com/settings/tokens
# ------------------------------------------------------------------------------
USE_GITHUB_TOKEN=false
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ------------------------------------------------------------------------------
# Hugging Face CLI (install_hf.sh)
# HF_TOKEN     : token d'acces HF pour hf auth login automatique
#                Creer un token sur : https://huggingface.co/settings/tokens
# HF_HOME      : (optionnel) repertoire de cache HF (defaut : ~/.cache/huggingface)
#                Utile pour pointer vers un disque de stockage plus grand
# ------------------------------------------------------------------------------
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# HF_HOME=/workspace/.cache/huggingface


# ------------------------------------------------------------------------------
# VS Code tunnel (install_vscode.sh)
# Nom du tunnel enregistre aupres de VS Code
# Note: l'auth utilise le device flow GitHub -- ne peut pas etre automatisee
# ------------------------------------------------------------------------------
VSCODE_TUNNEL_NAME=my-tunnel-name


# ------------------------------------------------------------------------------
# Options (install_all.sh)
# Decommentez pour personnaliser les versions
# ------------------------------------------------------------------------------
# NODE_VERSION=22
